# Required for AI analysis
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: enables Google Sign-In in Settings
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Optional: enables browser-side daily API sync/cache refresh.
# Keep false to use app-owned internal snapshot as primary data source.
VITE_ENABLE_RUNTIME_SYNC=false
